{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "melbourne-cartogram",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-13",
  "routes": [
    {
      "pattern": "castrio.me/melbourne*",
      "zone_name": "castrio.me"
    }
  ],
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}
